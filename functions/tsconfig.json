{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitAny": false,
    "outDir": ".",
    "preserveConstEnums": true,
    "sourceMap": true,
    "target": "ES2020",
    "lib": ["ES2020"],
    "rootDir": "src",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
