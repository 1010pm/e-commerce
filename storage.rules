rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allows anyone to read images
    // Allows any authenticated user to upload, update, or delete
    
    match /products/{allPaths=**} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }
    
    match /categories/{allPaths=**} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }

    // Default rules for other paths
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
